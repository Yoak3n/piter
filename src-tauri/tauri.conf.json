{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "piter",
  "version": "0.1.0",
  "identifier": "com.yoa.piter",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:all",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "./resources/pi": "pi",
      "../dist": "frontend",
      "../web/dist": "web-frontend"
    }
  }
}
